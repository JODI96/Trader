# ─── Binance API ───────────────────────────────────────────────────────────────
# Get from: https://www.binance.com/en/my/settings/api-management
# For testing use testnet: https://testnet.binancefuture.com
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# true  = use Binance Futures TESTNET (safe, no real money)
# false = use LIVE Binance Futures (real money — be careful!)
BINANCE_TESTNET=true

# ─── Symbol ────────────────────────────────────────────────────────────────────
SYMBOL=BTCUSDT

# ─── Account ───────────────────────────────────────────────────────────────────
INITIAL_BALANCE=10000
LEVERAGE=3

# Risk per trade as fraction of balance (0.005 = 0.5%)
RISK_PER_TRADE=0.015

# Minimum Risk:Reward ratio (3.0 = 1:3)
MIN_RR_RATIO=3.0

# Max stop-losses per session before trading is halted
MAX_LOSSES_PER_SESSION=3

# ─── Alert Settings ────────────────────────────────────────────────────────────
ALERT_BEEP_COUNT=3
